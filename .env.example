# 复制为 apps/api/.env 使用
# 云环境（.cursor/start.sh 默认创建的库）：
DATABASE_URL="postgresql://mandarin:mandarin@localhost:5432/mandarin?schema=public"

# JWT 密钥（生产请替换为强随机值）
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="7d"

# 后端服务端口
API_PORT=3000

# 前端可访问的后端地址（web 用）
VITE_API_BASE_URL="http://localhost:3000"
